<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zz.mapper.TeacherMapper">
    <select id="queryTeacherByWorkId" resultType="Teacher">
        select *
        from teacher
        where work_id = #{workId};
    </select>

    <select id="queryTeacherRecordByPage" resultType="Teacher">
        select * from teacher where 1=1
        <if test="name != null and name != ''">
            and name like #{name}
        </if>
        limit #{page},#{limit}
    </select>

    <select id="countsTeacherRecord" resultType="Teacher">
        select count(*) counts from teacher where 1=1
        <if test="name != null and name !=''">
            and name like #{name}
        </if>
    </select>
    <insert id="addTeacher" parameterType="Teacher">
        insert into teacher(name, sex, age, work_id)
        values (#{teacher.name}, #{teacher.sex}, #{teacher.age}, #{teacher.workId})
    </insert>

    <select id="queryTeacherRecordById" resultType="Teacher">
        select *
        from teacher
        where id = #{id}
    </select>

</mapper>